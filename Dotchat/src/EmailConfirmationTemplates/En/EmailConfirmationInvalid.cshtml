<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Email Confirmation</title>
    <style>
            @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Fraunces:ital,wght@0,700;1,400&display=swap');

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                background-color: #f5f4f0;
                font-family: 'DM Sans', sans-serif;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 40px 16px;
                background-image: radial-gradient(circle at 20% 20%, #ede8d6 0%, transparent 50%), radial-gradient(circle at 80% 80%, #e8e0c8 0%, transparent 50%);
            }

            .card {
                background: #ffffff;
                border-radius: 16px;
                max-width: 520px;
                width: 100%;
                overflow: hidden;
                box-shadow: 0 4px 24px rgba(0,0,0,0.07), 0 1px 4px rgba(0,0,0,0.04);
            }

            .card-header {
                background-color: #4F46E5;
                padding: 28px 40px;
                text-align: center;
            }

                .card-header h1 {
                    font-family: 'Fraunces', serif;
                    font-weight: 700;
                    font-size: 22px;
                    color: #ffffff;
                    letter-spacing: -0.3px;
                }

            .card-body {
                padding: 44px 48px;
                text-align: center;
            }

            .icon-wrap {
                width: 72px;
                height: 72px;
                border-radius: 50%;
                background-color: #fffbeb;
                border: 2px solid #fcd34d;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 28px;
            }

                .icon-wrap svg {
                    width: 34px;
                    height: 34px;
                }

            .card-body h2 {
                font-family: 'Fraunces', serif;
                font-size: 26px;
                font-weight: 700;
                color: #111827;
                margin-bottom: 12px;
                letter-spacing: -0.4px;
            }

            .card-body p {
                font-size: 15px;
                color: #6B7280;
                line-height: 1.65;
                margin-bottom: 12px;
            }

                .card-body p strong {
                    color: #374151;
                    font-weight: 600;
                }

            .divider {
                border: none;
                border-top: 1px solid #E5E7EB;
                margin: 24px 0;
            }

            .hint {
                font-size: 13px;
                color: #9CA3AF;
                line-height: 1.6;
                margin-bottom: 28px !important;
            }

            .btn {
                display: inline-block;
                background-color: #4F46E5;
                color: #ffffff;
                padding: 13px 30px;
                border-radius: 8px;
                text-decoration: none;
                font-size: 15px;
                font-weight: 600;
                letter-spacing: 0.1px;
            }

                .btn:hover {
                    background-color: #4338CA;
                }

            .card-footer {
                background-color: #F9FAFB;
                padding: 20px 48px;
                text-align: center;
                border-top: 1px solid #E5E7EB;
            }

                .card-footer p {
                    font-size: 12px;
                    color: #9CA3AF;
                }
    </style>
</head>

<body>
    <div class="card">

        <div class="card-header">
            <h1>@Model.AppName</h1>
        </div>

        <div class="card-body">

            <div class="icon-wrap">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="12" cy="12" r="11" stroke="#F59E0B" stroke-width="1.5" />
                    <path d="M12 7v5.5l3 3" stroke="#F59E0B" stroke-width="2"
                          stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>

            <h2>Link Invalid</h2>

            <p>
                Your email address has either already been confirmed or the
                confirmation link has expired.
            </p>

            <hr class="divider" />

            <p class="hint">
                You can request a new confirmation link at any time from your
                <strong>account settings</strong>.
            </p>

            <a href="@Model.ResendUrl" class="btn">Request New Link</a>

        </div>

        <div class="card-footer">
            <p>&copy; @DateTime.Now.Year @Model.AppName</p>
        </div>

    </div>
</body>
</html>